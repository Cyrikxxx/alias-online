# Скопируй в .env и заполни своими значениями.
# .env в .gitignore — реальные секреты в репозиторий не попадают.

# PostgreSQL (Neon). Строка подключения из дашборда Neon.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Redis (Upstash). Протокольный URL (rediss://), НЕ REST API.
REDIS_URL=rediss://default:PASSWORD@HOST.upstash.io:6379

# HMAC-секрет для подписи WebSocket-токенов.
# Сгенерировать: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# ВАЖНО: одно и то же значение на web (Vercel) и ws (Railway).
WS_TOKEN_SECRET=replace-with-64+-char-random-hex

# URL WS-сервера для клиента.
# Локально: http://localhost:3001
# На проде (Vercel env): https://<твой-сервис>.up.railway.app
NEXT_PUBLIC_WS_URL=http://localhost:3001

# Только для прод-сервера ws (Railway env), не нужно локально:
# WS_CORS_ORIGIN=https://<твоё-приложение>.vercel.app
# NODE_ENV=production
